# Copy this file to .env before running:
#   cp deploy/compose/.env.example deploy/compose/.env
# Then replace every placeholder value with a deployment-specific secret.

TRAEFIK_DOMAIN=<set-public-domain>
TRAEFIK_ACME_EMAIL=<set-acme-email>
TRAEFIK_TLS_ENABLED=true

SPECLIST_API_IMAGE=ghcr.io/interactivelearningplatform/fastspec/speclist-api:latest
SPECLIST_WEB_IMAGE=ghcr.io/interactivelearningplatform/fastspec/speclist-web:latest

POSTGRES_DB=speclist
POSTGRES_USER=speclist
POSTGRES_PASSWORD=<set-strong-postgres-password>

CLICKHOUSE_DB=speclist
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=<set-strong-clickhouse-password>

VALKEY_PASSWORD=<set-strong-valkey-password>
QDRANT_API_KEY=<set-strong-qdrant-api-key>

CROWDSEC_ENROLL_KEY=<set-crowdsec-enroll-key>
CROWDSEC_BOUNCER_KEY=<set-crowdsec-bouncer-key>

VAULT_ADDR=https://vault.example.internal
VAULT_ROLE=speclist-platform

SPECLIST_REPO_ROOT=/workspace
